@{
    ViewData["Title"] = "Home";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" />
}

<main class="container">
    <h1 class="text-center jobseek-main-text">
        Finally, a Job Board With Real Jobs.
        No Fake Listings. No Wasted Applications.
    </h1>
    <p class="text-center fs-5 w-75 m-auto">Jobseek understands your time is valuable therefore we verify every listing so you don’t waste applications on fake job postings, outdated roles, or data-collection traps.</p>
    <br />
    <div class="container">
        <div class="row mt-4">
            <div class="col-lg-6 col-sm-12 p-4 service-card">
                <h2 class="text-center jobseek-main-text">Why use Jobseek?</h2>
                <hr />
                <ul class="fs-5">
                    <li><span class="fw-bold jobseek-shadow-text">Verified Employer:</span> Companies must confirm their identity and business details</li>
                    <li><span class="fw-bold jobseek-shadow-text">Active Hiring Only:</span> Roles must be open and budget-approved</li>
                    <li><span class="fw-bold jobseek-shadow-text">Fresh Listings:</span> Jobs automatically expire if not updated</li>
                    <li><span class="fw-bold jobseek-shadow-text">No Resume Farming:</span> Listings posted only to collect data are removed</li>
                    <li><span class="fw-bold jobseek-shadow-text">Manual & Automated Checks:</span> We review postings to catch suspicious or inactive roles</li>
                </ul>
            </div>
            <div class="col-lg-6 col-sm-12 p-4">

                <img height="350px" width="100%" class="rounded-3" alt="people at work" src="~/imgs/heroimg.webp" />
            </div>
        </div>
    </div>
    <br />
    <div class="container">
        <h2 class="text-center jobseek-main-text">What We Offer.</h2>
        <br />
        <div class="row g-4">

            <div class="col-lg-4">
                <div class="jobseek-background-highlight p-4 d-flex flex-column gap-2 h-100 service-card">
                    <h4 class="jobseek-dark-text">Smart Resume & Cover Letter Uploads</h4>
                    <p>
                        Upload once, apply everywhere.
                        Store multiple resumes and tailored cover letters so you can apply faster without starting from scratch each time.
                    </p>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="jobseek-background-highlight p-4 d-flex flex-column gap-2 h-100 service-card">
                    <h4 class="jobseek-dark-text">Direct Messaging With Employers</h4>
                    <p>
                        No more application black holes.
                        Chat directly with employers and recruiters to ask questions, follow up, and move faster in the hiring process.
                    </p>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="jobseek-background-highlight p-4 d-flex flex-column gap-2 h-100 service-card">
                    <h4 class="jobseek-dark-text">Verified, Active Job Listings</h4>
                    <p>
                        Every role is checked to make sure companies are actually hiring — so your applications go to real openings.
                    </p>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="jobseek-background-highlight p-4 d-flex flex-column gap-2 h-100 service-card">
                    <h4 class="jobseek-dark-text">Fast Applications</h4>
                    <p>
                        Apply in minutes, not hours.
                        Your profile, resume, and details are saved so you can focus on opportunities — not forms.
                    </p>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="jobseek-background-highlight p-4 d-flex flex-column gap-2 h-100 service-card">
                    <h4 class="jobseek-dark-text">Application Updates & Notifications</h4>
                    <p>
                        Know what’s happening.
                        Get notified when employers view your application or send a message.
                    </p>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="jobseek-background-highlight p-4 d-flex flex-column gap-2 h-100 service-card">
                    <h4 class="jobseek-dark-text">Personalized Job Matches</h4>
                    <p>
                        Stop scrolling endlessly.
                        Jobseek recommends roles based on your skills, experience, and interests — so you see jobs that actually fit you.
                    </p>
                </div>
            </div>

        </div>
    </div>

</main>
