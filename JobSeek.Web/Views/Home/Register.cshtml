@using JobSeek.Web.Models
@model RegisterViewModel

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" />
}

<div class="container">
    <div class="row">
        <div class="auth-form w-50 m-auto p-5">
            <h1 class="text-center">Please enter your information</h1>

            <form asp-action="AuthorizeAccount" method="post" class="d-flex flex-column gap-4 mt-5">

                <div class="d-flex justify-content-center gap-3">
                    <div class="w-100">
                        <input asp-for="UserAccountFormModel.FirstName" class="auth-input form-control" placeholder="First Name" />
                        <span asp-validation-for="UserAccountFormModel.FirstName" class="text-danger"></span>
                    </div>

                    <div class="w-100">
                        <input asp-for="UserAccountFormModel.LastName" class="auth-input form-control" placeholder="Last Name" />
                        <span asp-validation-for="UserAccountFormModel.LastName" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-center gap-3">
                    <div class="w-100">
                        <input asp-for="UserAccountFormModel.Email" class="auth-input form-control" placeholder="Email" />
                        <span asp-validation-for="UserAccountFormModel.Email" class="text-danger"></span>
                    </div>

                    <div class="w-100">
                        <input asp-for="UserAccountFormModel.Password" class="auth-input form-control" type="password" placeholder="Password" />
                        <span asp-validation-for="UserAccountFormModel.Password" class="text-danger"></span>
                    </div>
                </div>

                <div>
                    <input asp-for="UserAccountFormModel.DateOfBirth" class="auth-input form-date form-control" type="date" />
                    <span asp-validation-for="UserAccountFormModel.DateOfBirth" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-center gap-3">
                    <div class="w-100">
                        <select id="country" asp-for="UserAccountFormModel.CountryID" class="auth-input form-select">
                            <option value="0" selected>Country</option>
                            @{
                                foreach(var country in Model.Countries)
                                {
                                    <option value=@country.CountryID>@country.Name</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="UserAccountFormModel.CountryID" class="text-danger"></span>
                    </div>

                    <div class="w-100">
                        <input id="state" asp-for="UserAccountFormModel.StateName" type="text" class="auth-input form-control" placeholder="State / Province" />
                        <span asp-validation-for="UserAccountFormModel.StateName" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-center gap-3">
                    <div class="w-100">
                        <input asp-for="UserAccountFormModel.City" class="auth-input form-control" />                         
                        <span asp-validation-for="UserAccountFormModel.City" class="text-danger"></span>
                    </div>

                    <div class="w-100">
                        <input asp-for="UserAccountFormModel.ZipCode" class="auth-input form-control" placeholder="Postal/Zip Code" />
                        <span asp-validation-for="UserAccountFormModel.ZipCode" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary w-25">Next</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts 
{
    <script src="~/js/register.js"></script>
}

